# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# debug scripts (kept locally, not committed or deployed)
/scripts/debug/
next-env.d.ts
.worktrees/

# databases
*.db
*.sqlite
*.sqlite3
prisma/dev.db
prisma/migrations/dev/

# test artifacts
/playwright-report
/test-results
/playwright/.cache

# logs
*.log

# editor
.vscode/
.idea/

.playwright-cli/

# graphify
graphify-out/
backups/

# agent harness (local-only)
.opencode/

# agent ephemeral planning docs
docs/superpowers/plans/

# one-off migration scripts (already executed)
create-table.ts
fix-perms.ts
recreate-table.ts
scripts/crear-factura-demo.ts

# SSH keys
hermes
hermes.pub

# Serwist (generated service worker)
public/sw*
public/swe-worker*

# QA artifacts
reports/
screenshots/
