generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ====================
// ENUMS
// ====================

enum EstadoPedido {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  CANCELADO
  ANULADO
}

enum EstadoEntrega {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  CANCELADO
  ANULADO
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  ANTICIPADO
  VENCIDO
  ANULADO
}

enum OrigenPedido {
  PEDIDO
  VENTA_RAPIDA
  VENTA_LIBRE
  RECURRENTE
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
  BONO
}

enum RolUsuario {
  ADMIN
  ASISTENTE
  CONTADOR
  REPARTIDOR
  SELLADOR
  EMPACADOR
  ENTUBADOR
}

enum TipoPagoTrabajador {
  COMISION
  FIJO
  MIXTO
}

enum EstadoNomina {
  PENDIENTE
  PAGADA
  ANULADA
}

enum EstadoEmbarque {
  ABIERTO
  EN_RUTA
  CERRADO
  CANCELADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  ANULADA
  PARCIAL
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

enum CasoStatus {
  ABIERTO
  EN_PROCESO
  RESUELTO
  CERRADO
}

// ====================
// USUARIOS
// ====================

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  password           String
  nombre             String     @default("")
  apellido           String     @default("")
  rol                RolUsuario @default(ASISTENTE)
  activo             Boolean    @default(true)
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now()) @db.Timestamptz()
  updatedAt          DateTime   @updatedAt @db.Timestamptz()

  trabajador Trabajador?

  clientesCreados     Cliente[]             @relation("ClienteCreador")
  pedidosCreados      Pedido[]              @relation("PedidoCreador")
  facturasCreadas     Factura[]             @relation("FacturaCreador")
  embarquesCreados    Embarque[]            @relation("EmbarqueCreador")
  gastosCreados       Gasto[]               @relation("GastoCreador")
  produccionesCreadas Produccion[]          @relation("ProduccionCreador")
  nominasCreadas      Nomina[]              @relation("NominaCreador")
  comprasCreadas      CompraInsumo[]        @relation("CompraCreador")
  insumosCreados      Insumo[]              @relation("InsumoCreador")
  proveedoresCreados  Proveedor[]           @relation("ProveedorCreador")
  trabajadoresCreados Trabajador[]          @relation("TrabajadorCreador")
  rutasCreadas        Ruta[]                @relation("RutaCreador")
  negociosCreados     Negocio[]             @relation("NegocioCreador")
  plantillasCreadas   PlantillaRecurrente[] @relation("PlantillaCreador")

  casosCreados   Caso[]       @relation("CasoCreador")
  casosAsignados Caso[]       @relation("CasoAsignado")
  eventosCaso    CasoEvento[] @relation("CasoEventoUser")

  pedidoItemsAutorizados PedidoItem[] @relation("PedidoItemAutorizador")

  deudasCreadas DeudaTrabajador[] @relation("DeudaCreador")
}

// ====================
// RUTA
// ====================

model Ruta {
  id          String  @id @default(cuid())
  createdById String?
  createdBy   User?   @relation("RutaCreador", fields: [createdById], references: [id])
  nombre      String
  dias        String?
  activo      Boolean @default(true)

  repartidorId         String?
  repartidor           Trabajador? @relation("RutaRepartidor", fields: [repartidorId], references: [id])
  repartidorRespaldoId String?
  repartidorRespaldo   Trabajador? @relation("RutaRespaldo", fields: [repartidorRespaldoId], references: [id])

  horarioInicio String?
  horarioFin    String?

  clientes  Cliente[]
  negocios  Negocio[]  @relation("RutaNegocio")
  embarques Embarque[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
  @@index([repartidorId])
  @@index([repartidorRespaldoId])
}

// ====================
// CLIENTE
// ====================

model Cliente {
  id          String  @id @default(cuid())
  createdById String?
  createdBy   User?   @relation("ClienteCreador", fields: [createdById], references: [id])

  nombre        String
  apellido      String?
  telefono      String
  direccion     String?
  barrio        String?
  referencia  String?
  linkUbicacion String?

  // Geo coords — Bloque 1 (Ruta por Cercanía).
  // Backfilled desde linkUbicacion parseado, o desde mediana de
  // Pedido.gpsLat/gpsLng confirmados, o desde Negocio. `geocodeOrigen`
  // audita de dónde salieron las coords para que el admin pueda
  // revalidarlas si cambian.
  lat           Decimal? @db.Decimal(10, 6)
  lng           Decimal? @db.Decimal(10, 6)
  geocodeOrigen String?  // 'PARSED_URL' | 'GPS_HISTORIAL' | 'NEGOCIO' | 'MANUAL'
  geocodeAt     DateTime? @db.Timestamptz()

  // FASE 3 CONTRACT: contactos legacy eliminada. Ahora es relación.
  contactos ContactoCliente[]

  nombreNegocio String?
  tipoNegocio       String?
  fuente            String?
  horaApertura      String?
  preciosEspeciales String?

  rutaId String?
  ruta   Ruta?   @relation(fields: [rutaId], references: [id])

  frecuencia String @default("NINGUNA")
  cadaNDias  Int?

  ultEntrega  DateTime? @db.Timestamptz()
  proxEntrega DateTime? @db.Timestamptz()

  habAgua       Boolean @default(true)
  habHielo      Boolean @default(true)
  habBotellon   Boolean @default(true)
  habBolsaAgua  Boolean @default(true)
  habBolsaHielo Boolean @default(true)

  // NUEVOS — control y verificación
  verificado          Boolean    @default(false)
  verificadoEn        DateTime?  @db.Timestamptz()
  creadoPorRol        RolUsuario @default(ASISTENTE)
  bloqueado           Boolean    @default(false)
  reclamaciones       Int        @default(0)
  limitePedidosFiados Int?       @default(3)

  // NEGOCIOS — un cliente puede ser dueño de varios negocios
  negocios         Negocio[]
  negocioDefaultId String?   @unique
  negocioDefault   Negocio?  @relation("NegocioDefault", fields: [negocioDefaultId], references: [id])

  plantillaRecurrente PlantillaRecurrente?

  notas  String?
  activo Boolean @default(true)

  // FIX Fase 2 §3.4: saldo a favor del cliente. Si un pago excede el
  // total del pedido, el excedente queda como crédito reutilizable.
  // @default(0) garantiza que clientes existentes tengan 0.
  saldoFavor Decimal @default(0) @db.Decimal(10, 2)

  // Offline-first dedup: si la request llega con un offlineId ya existente,
  // el server devuelve el cliente creado en lugar de duplicar.
  offlineId String? @unique

  pedidos  Pedido[]
  facturas Factura[]
  abonos   Abono[]
  casos    Caso[]    @relation("CasoCliente")

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([rutaId])
  @@index([createdById])
  @@index([telefono])
  @@index([activo])
  @@index([barrio])
  @@index([frecuencia])
  @@index([proxEntrega])
  @@index([verificado])
  @@index([bloqueado])
  @@index([offlineId])
  // Geo: partial index (solo clientes con coords) para queries de clustering
  // y bounding box. WHERE lat IS NOT NULL reduce el tamaño del índice.
  @@index([lat, lng])
}

// ====================
// NEGOCIO (sucursales de un cliente)
// ====================

model Negocio {
  id          String  @id @default(cuid())
  createdById String?
  createdBy   User?   @relation("NegocioCreador", fields: [createdById], references: [id])

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  nombre        String
  tipoNegocio   String?
  direccion     String? // si null, fallback a cliente.direccion
  barrio        String? // si null, fallback a cliente.barrio
  referencia    String?
  linkUbicacion String?

  // Geo coords — Bloque 1. Misma semántica que Cliente.lat/lng.
  // Si Negocio tiene coords propias, gana sobre Cliente. Si no, fallback a Cliente.
  lat           Decimal? @db.Decimal(10, 6)
  lng           Decimal? @db.Decimal(10, 6)

  horaApertura  String?

  rutaId String?
  ruta   Ruta?   @relation("RutaNegocio", fields: [rutaId], references: [id])

  preciosEspeciales String? // si null, fallback a cliente.preciosEspeciales

  habAgua       Boolean @default(true)
  habHielo      Boolean @default(true)
  habBotellon   Boolean @default(true)
  habBolsaAgua  Boolean @default(true)
  habBolsaHielo Boolean @default(true)

  frecuencia String?
  cadaNDias  Int?

  plantillaRecurrente PlantillaRecurrente?

  pedidos        Pedido[]
  facturas       Factura[]
  abonos         Abono[]
  casos          Caso[]    @relation("CasoNegocio")
  // Relation for Cliente.negocioDefault
  clienteDefault Cliente?  @relation("NegocioDefault")
  activo         Boolean   @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([clienteId])
  @@index([rutaId])
  @@index([activo])
  @@index([barrio])
}

// ====================
// PLANTILLA RECURRENTE
// ====================

model PlantillaRecurrente {
  id               String              @id @default(cuid())
  // NUEVO: relación principal a Negocio
  negocioId        String?             @unique
  negocio          Negocio?            @relation(fields: [negocioId], references: [id])
  // LEGACY: mantener para compatibilidad durante migración
  clienteId        String?             @unique
  cliente          Cliente?            @relation(fields: [clienteId], references: [id])
  activo           Boolean             @default(true)
  cadaNDias        Int                 @default(7)
  tipo             String              @default("ENVIO")
  canal           String   @default("DOMICILIO")
  horaPreferida   String?
  // FASE 3 CONTRACT: productos legacy eliminada. Ahora es relación.
  productos    PlantillaProducto[]
  ultimaGeneracion DateTime? @db.Timestamptz()
  proxGeneracion   DateTime?           @db.Timestamptz()
  saltos           String[]
  pausaHasta       DateTime?           @db.Timestamptz()
  notas            String?
  createdById      String?
  createdBy        User?               @relation("PlantillaCreador", fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @db.Timestamptz()
  updatedAt        DateTime            @updatedAt @db.Timestamptz()

  @@index([activo, proxGeneracion])
  @@index([clienteId])
  @@index([negocioId])
}

// ====================
// TRABAJADOR
// ====================

model Trabajador {
  id          String             @id @default(cuid())
  createdById String?
  createdBy   User?              @relation("TrabajadorCreador", fields: [createdById], references: [id])
  userId      String?            @unique
  user        User?              @relation(fields: [userId], references: [id])
  nombre      String
  rol         String
  tipoPago    TipoPagoTrabajador @default(COMISION)

  usaMoto      Boolean @default(false)
  capacidadKg  Int     @default(500)
  comPacaAgua  Decimal @default(200) @db.Decimal(10, 2)
  comPacaHielo Decimal @default(200) @db.Decimal(10, 2)
  comBotellon  Decimal @default(200) @db.Decimal(10, 2)

  comRepartAgua     Decimal @default(0) @db.Decimal(10, 2)
  comRepartHielo    Decimal @default(0) @db.Decimal(10, 2)
  comRepartBotellon Decimal @default(0) @db.Decimal(10, 2)

  salarioFijo Decimal @default(0) @db.Decimal(10, 2)

  deudaReposAgua  Decimal @default(0) @db.Decimal(10, 2)
  deudaReposHielo Decimal @default(0) @db.Decimal(10, 2)
  telefono        String?
  activo          Boolean @default(true)

  embarques    Embarque[]
  producciones Produccion[]
  nominas      Nomina[]
  gpsTracks    GpsTrack[]
  descuentos   DescuentoRepartidor[]
  deudas       DeudaTrabajador[]

  casosRepartidor Caso[] @relation("CasoRepartidor")

  rutasAsignadas Ruta[] @relation("RutaRepartidor")
  rutasRespaldo  Ruta[] @relation("RutaRespaldo")

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
  @@index([rol, activo])
}

// ====================
// NOMINA
// ====================

model Nomina {
  id           String     @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("NominaCreador", fields: [createdById], references: [id])
  trabajadorId String
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])

  fechaInicio DateTime @db.Timestamptz()
  fechaFin    DateTime @db.Timestamptz()

  entregasAgua     Int @default(0)
  entregasHielo    Int @default(0)
  entregasBotellon Int @default(0)

  comEntregasAgua     Decimal @default(0) @db.Decimal(10, 2)
  comEntregasHielo    Decimal @default(0) @db.Decimal(10, 2)
  comEntregasBotellon Decimal @default(0) @db.Decimal(10, 2)
  totalComisiones     Decimal @default(0) @db.Decimal(10, 2)

  // NUEVOS — comisiones por origen
  comVentaLibreAgua  Decimal @default(0) @db.Decimal(10, 2)
  comVentaLibreHielo Decimal @default(0) @db.Decimal(10, 2)
  comPedidoAgua      Decimal @default(0) @db.Decimal(10, 2)
  comPedidoHielo     Decimal @default(0) @db.Decimal(10, 2)

  salario Decimal @default(0) @db.Decimal(10, 2)
  total   Decimal @db.Decimal(10, 2)

  // Deducciones aplicadas
  totalDescuentos Decimal @default(0) @db.Decimal(10, 2)
  descuentoDeudas Decimal @default(0) @db.Decimal(10, 2)

  estado    EstadoNomina @default(PENDIENTE)
  fechaPago DateTime?    @db.Timestamptz()

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  descuentosAplicados DescuentoRepartidor[] @relation("NominaDescuentos")
  deduccionesDeudas   DeduccionDeuda[]

  @@index([createdById])
  @@index([trabajadorId])
  @@index([estado])
}

// ====================
// PEDIDO (con legacy + nuevos campos)
// ====================

model Pedido {
  id          String    @id @default(cuid())
  numero      Int       @default(autoincrement())
  createdById String?
  createdBy   User?     @relation("PedidoCreador", fields: [createdById], references: [id])
  clienteId   String
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  negocioId   String?
  negocio     Negocio?  @relation(fields: [negocioId], references: [id])
  embarqueId  String?
  embarque    Embarque? @relation(fields: [embarqueId], references: [id])

  tipo  String @default("ENVIO")
  canal String @default("DOMICILIO")

  fechaEntrega DateTime? @db.Timestamptz()
  fecha        DateTime  @default(now()) @db.Timestamptz()

  // NUEVOS — estado desacoplado
  origen        OrigenPedido  @default(PEDIDO)
  estadoEntrega EstadoEntrega @default(PENDIENTE)
  estadoPago    EstadoPago    @default(PENDIENTE)

  // NUEVOS — control y trazabilidad
  promesaPagoFecha  DateTime? @db.Timestamptz()
  fotoEntrega       String?
  gpsLat            Decimal?  @db.Decimal(10, 6)
  gpsLng            Decimal?  @db.Decimal(10, 6)
  offlineId         String?   @unique
  recurrenteBatchId String? // batch id compartido por todos los pedidos de un batch de recurrentes
  // FIX Fase 1: dedup key dedicado para POST /api/pedidos/[id]/enviar.
  // Antes el dedup se hacia por estado (embarqueId+EN_RUTA), fragil si el
  // check externo y la tx se desincronizan. Ahora: el server persiste el
  // offlineId y el retry con el mismo offlineId retorna deduped: true.
  envioOfflineId    String?   @unique
  disputaAbierta    Boolean   @default(false)
  codigoVisita      String?

  // LEGACY — se mantiene para compatibilidad
  estado EstadoPedido @default(PENDIENTE)

  // Productos embebidos (DEPRECATED — leer desde items[])
  cPacaAguaPed   Int     @default(0)
  cPacaAguaEnt   Int     @default(0)
  precioPacaAgua Decimal @default(0) @db.Decimal(10, 2)

  cPacaHieloPed   Int     @default(0)
  cPacaHieloEnt   Int     @default(0)
  precioPacaHielo Decimal @default(0) @db.Decimal(10, 2)

  cBotellonFabPed   Int     @default(0)
  cBotellonFabEnt   Int     @default(0)
  precioBotellonFab Decimal @default(0) @db.Decimal(10, 2)

  cBotellonDomPed   Int     @default(0)
  cBotellonDomEnt   Int     @default(0)
  precioBotellonDom Decimal @default(0) @db.Decimal(10, 2)

  cBolsaAguaPed   Int     @default(0)
  cBolsaAguaEnt   Int     @default(0)
  precioBolsaAgua Decimal @default(0) @db.Decimal(10, 2)

  cBolsaHieloPed   Int     @default(0)
  cBolsaHieloEnt   Int     @default(0)
  precioBolsaHielo Decimal @default(0) @db.Decimal(10, 2)

  // Totales
  total       Decimal @default(0) @db.Decimal(10, 2)
  totalPagado Decimal @default(0) @db.Decimal(10, 2)
  saldo       Decimal @default(0) @db.Decimal(10, 2)

  repartidor    String?
  obs           String?
  horaPreferida String?

  // Referencia polimórfica: PlantillaRecurrente.id o null
  idOrigen String?

  // Relaciones nuevas
  items PedidoItem[]

  factura      Factura?
  pagos        Pago[]
  notasCredito NotaCredito[]
  abonos       Abono[]
  casos        Caso[]        @relation("CasoPedido")

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([clienteId])
  @@index([negocioId])
  @@index([embarqueId])
  @@index([fecha])
  @@index([estado])
  @@index([createdById])
  @@index([idOrigen])
  @@index([fecha, estado])
  @@index([clienteId, estado])
  @@index([estado, fecha])
  @@index([embarqueId, estado])
  @@index([canal, estado])
  @@index([fechaEntrega])
  // NUEVOS índices
  @@index([origen])
  @@index([estadoEntrega])
  @@index([estadoPago])
  @@index([offlineId])
  @@index([recurrenteBatchId])
  @@index([envioOfflineId])
  @@index([clienteId, estadoEntrega, estadoPago])
  @@index([promesaPagoFecha])
}

// ====================
// PEDIDO ITEM (nueva tabla normalizada)
// ====================

model PedidoItem {
  id       String @id @default(cuid())
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  producto     String // PACA_AGUA, PACA_HIELO, BOTELLON, BOLSA_AGUA, BOLSA_HIELO
  cantPedido   Int     @default(0)
  cantEntrega  Int     @default(0)
  precio       Decimal @default(0) @db.Decimal(10, 2)
  subtotal     Decimal @default(0) @db.Decimal(10, 2)
  precioOrigen String  @default("base") // manual, cliente, volumen, base

  // commit 0c plan antifraude: cuando precioOrigen = 'manual', la alerta
  // CAMBIO_PRECIO_BRUSCO skipea SOLO si autorizadoPorAdmin = true. Sin
  // esta marca, cualquier precio manual es sospechoso (vector de fraude).
  autorizadoPorAdmin Boolean   @default(false)
  autorizadoPorId    String?
  autorizadoPor      User?     @relation("PedidoItemAutorizador", fields: [autorizadoPorId], references: [id], onDelete: SetNull)
  autorizadoEn       DateTime? @db.Timestamptz()

  @@index([pedidoId])
  @@index([producto])
}

// ====================
// PAGO
// ====================

model Pago {
  id        String     @id @default(cuid())
  pedidoId  String
  pedido    Pedido     @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  metodo    MetodoPago
  monto     Decimal    @db.Decimal(10, 2)
  offlineId String? // batch id para dedup offline-first (pagos del mismo batch comparten offlineId)
  createdAt DateTime   @default(now()) @db.Timestamptz()

  @@index([pedidoId])
  @@index([offlineId])
}

// ====================
// EMBARQUE
// ====================

model Embarque {
  id           String         @id @default(cuid())
  createdById  String?
  createdBy    User?          @relation("EmbarqueCreador", fields: [createdById], references: [id])
  numero       Int            @default(autoincrement())
  numeroDia    Int            @default(0)
  fecha        DateTime       @default(now()) @db.Timestamptz()
  trabajadorId String
  trabajador   Trabajador     @relation(fields: [trabajadorId], references: [id])
  rutaId       String?
  ruta         Ruta?          @relation(fields: [rutaId], references: [id])
  horaSalida   DateTime?      @db.Timestamptz()
  horaLlegada  DateTime?      @db.Timestamptz()
  estado       EstadoEmbarque @default(ABIERTO)

  // Legacy — se mantiene para compatibilidad
  pacasAgua      Int @default(0)
  pacasHielo     Int @default(0)
  devueltasAgua  Int @default(0)
  devueltasHielo Int @default(0)
  rotasAgua      Int @default(0)
  rotasHielo     Int @default(0)

  // Tipo de motocarga
  tipoMoto String?

  // Dinero
  baseDinero      Decimal @default(0) @db.Decimal(10, 2)
  dineroEntregado Decimal @default(0) @db.Decimal(10, 2)

  // Snapshot de stock al crear
  stockSnapshot Json?

  // NUEVO — código de visita del día
  codigoVisita String?

  // Offline-first dedup: cada acción (update, cancel) escribe su offlineId aquí.
  // Si una request con el mismo offlineId llega de nuevo, el server detecta que
  // la acción ya fue aplicada y devuelve el estado actual sin re-aplicar.
  offlineId String?

  obs String?

  // Bloque 2: orden de visita optimizado por TSP heurístico (NN + 2-opt).
  // Array de {pedidoId, lat, lng, distanciaAcumulada, orden}.
  // Se persiste al llamar POST /api/embarques/[id]/optimizar-orden.
  // El repartidor ve la lista de pedidos en este orden en /repartidor.
  ordenVisita  Json?
  optimizadoEn DateTime?

  pedidos   Pedido[]
  gpsTracks GpsTrack[]
  productos EmbarqueProducto[]
  gastos    Gasto[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([trabajadorId, fecha, numeroDia], name: "embarque_trabajador_fecha_numeroDia_unique")
  @@index([createdById])
  @@index([trabajadorId])
  @@index([rutaId])
  @@index([fecha])
  @@index([estado])
  @@index([trabajadorId, fecha, numeroDia])
  @@index([offlineId])
}

// ====================
// EMBARQUE PRODUCTO (conciliación por producto)
// ====================

model EmbarqueProducto {
  id         String   @id @default(cuid())
  embarqueId String
  embarque   Embarque @relation(fields: [embarqueId], references: [id], onDelete: Cascade)

  producto  String // PACA_AGUA, PACA_HIELO, BOTELLON, BOLSA_AGUA, BOLSA_HIELO
  cargadas  Int    @default(0)
  devueltas Int    @default(0)
  cambios   Int    @default(0)
  rotas     Int    @default(0)

  @@unique([embarqueId, producto])
  @@index([embarqueId])
}

// ====================
// GPS TRACK (nueva)
// ====================

model GpsTrack {
  id           String   @id @default(cuid())
  embarqueId   String
  trabajadorId String
  lat          Decimal  @db.Decimal(10, 6)
  lng          Decimal  @db.Decimal(10, 6)
  timestamp    DateTime @db.Timestamptz()
  synced       Boolean  @default(false)

  embarque   Embarque   @relation(fields: [embarqueId], references: [id])
  trabajador Trabajador @relation(fields: [trabajadorId], references: [id])

  @@index([embarqueId])
  @@index([trabajadorId, timestamp])
}

// ====================
// DESCUENTO REPARTIDOR (nueva)
// ====================

model DescuentoRepartidor {
  id               String   @id @default(cuid())
  embarqueId       String
  trabajadorId     String
  monto            Decimal  @db.Decimal(10, 2)
  motivo           String
  justificado      Boolean  @default(false)
  aplicadoEnNomina Boolean  @default(false)
  nominaId         String?
  fecha            DateTime @default(now()) @db.Timestamptz()

  trabajador Trabajador @relation(fields: [trabajadorId], references: [id])
  nomina     Nomina?    @relation("NominaDescuentos", fields: [nominaId], references: [id])

  @@index([trabajadorId])
  @@index([embarqueId])
  @@index([aplicadoEnNomina])
  @@index([nominaId])
}

// ====================
// FACTURA
// ====================

model Factura {
  id          String   @id @default(cuid())
  createdById String?
  createdBy   User?    @relation("FacturaCreador", fields: [createdById], references: [id])
  numero      String   @unique
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  negocioId   String?
  negocio     Negocio? @relation(fields: [negocioId], references: [id])
  pedidoId    String   @unique
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])

  fecha    DateTime @default(now()) @db.Timestamptz()
  subtotal Decimal  @db.Decimal(10, 2)
  total    Decimal  @db.Decimal(10, 2)

  estado EstadoFactura @default(EMITIDA)

  montoPagado Decimal @default(0) @db.Decimal(10, 2)
  saldo       Decimal @db.Decimal(10, 2)

  // Snapshot de datos de empresa al momento de emisión (inmutable)
  empresaNombre    String? @default("Agua Bambú SAS")
  empresaNit       String? @default("900.123.456-7")
  empresaDireccion String? @default("")
  empresaTelefono  String? @default("")
  empresaEmail     String? @default("")

  abonos       Abono[]
  notasCredito NotaCredito[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([clienteId])
  @@index([negocioId])
  @@index([estado])
  @@index([createdById])
  @@index([saldo])
  @@index([fecha])
}

// ====================
// CHECK CONSTRAINTS via raw SQL migration
// ====================
// IMPORTANTE: Prisma Schema Language NO soporta CHECK constraints.
// Los siguientes viven en migraciones SQL raw, NO en este schema.
// Para ver/editar: `prisma/migrations/20260610_add_check_constraints/`.
//
// Auditoría pre-aplicación (2026-06-10): 0 violaciones en las 8 reglas
// principales. Datos limpios → aplicación directa con NOT VALID + VALIDATE.
//
// Aplicados en 20260610_add_check_constraints:
//   chk_pedido_saldo_nonneg          saldo >= 0
//   chk_pedido_montopagado_le_total  totalPagado <= total
//   chk_pedido_saldo_calc            saldo = total - totalPagado
//   chk_pedido_total_nonneg          total >= 0
//   chk_pago_monto_pos               monto > 0
//   chk_factura_saldo_nonneg         saldo >= 0
//   chk_factura_montopagado_le_total montoPagado <= total
//   chk_factura_total_nonneg         total >= 0
//   chk_abono_monto_pos              monto > 0
//
// Pendientes (no críticos para Fase 3):
//   chk_precio_cantmin / chk_precio_rango / chk_precio_positivo
//   chk_nomina_fechas
//   chk_trabajador_rol / chk_trabajador_capacidad
//   chk_embarque_pacas
//   chk_gasto_monto
//   chk_compra_cantidad / chk_compra_monto
//   chk_insumo_stockmin
//
// ====================
// SECUENCIA PARA Factura.numero (Fase 3 §2.3)
// ====================
// IMPORTANTE: NO aplicada aún. Gated por respuesta DIAN:
//   - Si permite huecos → aplicar 20260610_add_factura_numero_seq (secuencia)
//   - Si exige consecutivo sin huecos → NO aplicar; usar row-lock
//     (SELECT ... FOR UPDATE sobre una fila contadora) en su lugar.
//
// La migración crea la secuencia con START WITH = MAX(numero) + 1
// para no colisionar con facturas existentes. Cuando se confirme la
// decisión, además hay que actualizar src/lib/sequence.ts para que
// getNextNumero() use la secuencia cuando seqName = 'factura_numero_seq'.
// -- Pedido: totalPagado no puede exceder total, saldo no negativo
// -- Pedido: totalPagado no puede exceder total, saldo no negativo
// ALTER TABLE "Pedido" ADD CONSTRAINT chk_pedido_saldo CHECK ("saldo" >= 0);
// ALTER TABLE "Pedido" ADD CONSTRAINT chk_pedido_totalpagado CHECK ("totalPagado" <= "total");
//
// -- Pago y Abono: monto positivo
// ALTER TABLE "Pago" ADD CONSTRAINT chk_pago_monto CHECK ("monto" > 0);
// ALTER TABLE "Abono" ADD CONSTRAINT chk_abono_monto CHECK ("monto" > 0);
//
// -- Factura: saldo no negativo, montoPagado no excede total
// ALTER TABLE "Factura" ADD CONSTRAINT chk_factura_saldo CHECK ("saldo" >= 0);
// ALTER TABLE "Factura" ADD CONSTRAINT chk_factura_montopagado CHECK ("montoPagado" <= "total");
//
// -- PrecioVolumen: cantMin positivo, coherencia rangos
// ALTER TABLE "PrecioVolumen" ADD CONSTRAINT chk_precio_cantmin CHECK ("cantMin" > 0);
// ALTER TABLE "PrecioVolumen" ADD CONSTRAINT chk_precio_rango CHECK ("cantMax" IS NULL OR "cantMax" >= "cantMin");
// ALTER TABLE "PrecioVolumen" ADD CONSTRAINT chk_precio_positivo CHECK ("precio" > 0);
//
// -- Nomina: fechas coherentes
// ALTER TABLE "Nomina" ADD CONSTRAINT chk_nomina_fechas CHECK ("fechaFin" >= "fechaInicio");
//
// -- Trabajador: roles válidos
// ALTER TABLE "Trabajador" ADD CONSTRAINT chk_trabajador_rol CHECK ("rol" IN ('SELLADOR', 'REPARTIDOR', 'ADMIN', 'CONTADOR'));
// ALTER TABLE "Trabajador" ADD CONSTRAINT chk_trabajador_capacidad CHECK ("capacidadKg" > 0);
//
// -- Embarque: conteos no negativos
// ALTER TABLE "Embarque" ADD CONSTRAINT chk_embarque_pacas CHECK ("pacasAgua" >= 0 AND "pacasHielo" >= 0);
//
// -- Gasto: monto positivo
// ALTER TABLE "Gasto" ADD CONSTRAINT chk_gasto_monto CHECK ("monto" > 0);
//
// -- CompraInsumo: cantidades positivas
// ALTER TABLE "CompraInsumo" ADD CONSTRAINT chk_compra_cantidad CHECK ("cantidad" > 0);
// ALTER TABLE "CompraInsumo" ADD CONSTRAINT chk_compra_monto CHECK ("montoTotal" > 0);
//
// -- Insumo: stock min no negativo
// ALTER TABLE "Insumo" ADD CONSTRAINT chk_insumo_stockmin CHECK ("stockMin" >= 0);

// ====================
// ABONO
// ====================

model Abono {
  id         String   @id @default(cuid())
  numero     String   @unique
  facturaId  String
  factura    Factura  @relation(fields: [facturaId], references: [id])
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  negocioId  String?
  negocio    Negocio? @relation(fields: [negocioId], references: [id])
  pedidoId   String?
  pedido     Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  monto      Decimal  @db.Decimal(10, 2)
  metodoPago String
  fecha      DateTime @default(now()) @db.Timestamptz()

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([facturaId])
  @@index([clienteId])
  @@index([negocioId])
  @@index([fecha])
  @@index([facturaId, fecha])
  @@index([pedidoId])
}

// ====================
// PRODUCCION
// ====================

model Produccion {
  id           String     @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("ProduccionCreador", fields: [createdById], references: [id])
  fecha        DateTime   @default(now()) @db.Timestamptz()
  turno        Turno
  trabajadorId String
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])

  // Comisiones agregadas (la desagregación por producto está en ProduccionItem)
  comSellTotal   Decimal @default(0) @db.Decimal(10, 2)
  comRepartTotal Decimal @default(0) @db.Decimal(10, 2)

  obs String?

  // Offline-first dedup: si la request llega con un offlineId ya existente,
  // el server devuelve la Produccion existente en lugar de duplicar.
  offlineId String? @unique

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  items ProduccionItem[]

  @@unique([trabajadorId, fecha, turno])
  @@index([createdById])
  @@index([fecha])
  @@index([trabajadorId, fecha])
  @@index([turno, fecha])
}

model ProduccionItem {
  id           String     @id @default(cuid())
  produccionId String
  produccion   Produccion @relation(fields: [produccionId], references: [id], onDelete: Cascade)

  // Producto: solo PACA_AGUA y PACA_HIELO. Botellones y bolsas son
  // passthrough (no tienen ciclo de stock), por eso no se trackean
  // como items de producción.
  producto String // 'PACA_AGUA' | 'PACA_HIELO'

  // Conteos del sellador
  conteoA   Int @default(0)
  conteoB   Int @default(0)
  producido Int @default(0) // (A+B)/2 redondeado

  // Snapshot al momento del cierre
  stockIni Int @default(0)
  ventas   Int @default(0)

  // Resultado
  stockFinEsperado Int @default(0)
  stockFinFisico   Int @default(0)
  diferencia       Int @default(0) // stockFinEsperado - stockFinFisico - perdidasTotales

  // Pérdidas
  filtradas      Int @default(0)
  rotas          Int @default(0)
  consumoInterno Int @default(0)

  // Comisión del sellador por este item
  comSellador Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([produccionId, producto])
  @@index([producto])
}

// ====================
// GASTO
// ====================

model Gasto {
  id          String    @id @default(cuid())
  createdById String?
  createdBy   User?     @relation("GastoCreador", fields: [createdById], references: [id])
  fecha       DateTime  @default(now()) @db.Timestamptz()
  categoria   String
  descripcion String
  monto       Decimal   @default(0) @db.Decimal(10, 2)
  responsable String?
  notas       String?
  embarqueId  String?
  embarque    Embarque? @relation(fields: [embarqueId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
  @@index([fecha])
  @@index([categoria, fecha])
  @@index([embarqueId])
}

// ====================
// PROVEEDOR
// ====================

model Proveedor {
  id            String  @id @default(cuid())
  createdById   String?
  createdBy     User?   @relation("ProveedorCreador", fields: [createdById], references: [id])
  nombre        String
  telefono      String?
  email         String?
  direccion     String?
  tipoProducto  String? @db.VarChar(100)
  observaciones String? @db.Text
  activo        Boolean @default(true)

  insumos Insumo[]
  compras CompraInsumo[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
}

// ====================
// INSUMO
// ====================

model Insumo {
  id          String  @id @default(cuid())
  createdById String?
  createdBy   User?   @relation("InsumoCreador", fields: [createdById], references: [id])
  nombre      String
  unidad      String
  stock       Decimal @default(0) @db.Decimal(10, 2)
  stockMin    Decimal @default(0) @db.Decimal(10, 2)
  precioUnit  Decimal @default(0) @db.Decimal(10, 2)
  activo      Boolean @default(true)

  proveedorId String?
  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id])

  compras CompraInsumo[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
}

// ====================
// COMPRA_INSUMO
// ====================

model CompraInsumo {
  id          String    @id @default(cuid())
  createdById String?
  createdBy   User?     @relation("CompraCreador", fields: [createdById], references: [id])
  numero      String    @unique
  proveedorId String
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])
  insumoId    String
  insumo      Insumo    @relation(fields: [insumoId], references: [id])
  cantidad    Decimal   @db.Decimal(10, 2)
  montoTotal  Decimal   @db.Decimal(10, 2)
  fecha       DateTime  @default(now()) @db.Timestamptz()

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([createdById])
  @@index([fecha])
  @@index([insumoId])
  @@index([proveedorId])
}

// ====================
// PRODUCTO
// ====================

model Producto {
  id                  String  @id @default(cuid())
  codigo              String  @unique
  nombre              String
  descripcion         String?
  unidad              String
  contenido           String?
  activo              Boolean @default(true)
  aplicaDomicilio     Boolean @default(false)
  sobreCostoDomicilio Decimal @default(0) @db.Decimal(10, 2)
  precioBase          Decimal @default(0) @db.Decimal(10, 2)

  precios PrecioVolumen[]

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

// ====================
// PRECIO_VOLUMEN
// ====================

model PrecioVolumen {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])

  cantMin Int     @default(1)
  cantMax Int?
  precio  Decimal @db.Decimal(10, 2)

  // Umbral minimo de alerta (commit 0c plan antifraude). Si el precio
  // de un item es < precioMinimo, la alerta PRECIO_POR_DEBAJO_TABLA
  // dispara. null = sin restriccion (alerta deshabilitada para esa fila).
  precioMinimo Decimal? @db.Decimal(10, 2)

  activo Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([productoId, cantMin])
  @@index([productoId])
  @@index([productoId, activo])
}

// ====================
// CONFIG
// ====================

model Config {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

// ====================
// CIERRE_DIA
// ====================

model CierreDia {
  id    String   @id @default(cuid())
  fecha DateTime @unique @db.Timestamptz()

  numPedidos  Int     @default(0)
  totalVentas Decimal @default(0) @db.Decimal(10, 2)

  // Por origen (nuevos)
  totalVentaRapida Decimal @default(0) @db.Decimal(10, 2)
  totalPedido      Decimal @default(0) @db.Decimal(10, 2)
  totalVentaLibre  Decimal @default(0) @db.Decimal(10, 2)

  fiadoVentaRapida Decimal @default(0) @db.Decimal(10, 2)
  fiadoPedido      Decimal @default(0) @db.Decimal(10, 2)
  fiadoVentaLibre  Decimal @default(0) @db.Decimal(10, 2)

  aguaVendida       Int @default(0)
  hieloVendido      Int @default(0)
  botellonVendido   Int @default(0)
  bolsaAguaVendida  Int @default(0)
  bolsaHieloVendida Int @default(0)

  cobrado       Decimal @default(0) @db.Decimal(10, 2)
  fiado         Decimal @default(0) @db.Decimal(10, 2)
  efectivo      Decimal @default(0) @db.Decimal(10, 2)
  nequi         Decimal @default(0) @db.Decimal(10, 2)
  daviplata     Decimal @default(0) @db.Decimal(10, 2)
  transferencia Decimal @default(0) @db.Decimal(10, 2)
  bono          Decimal @default(0) @db.Decimal(10, 2)

  baseDia    Decimal @default(0) @db.Decimal(10, 2)
  comisiones Decimal @default(0) @db.Decimal(10, 2)
  salarios   Decimal @default(0) @db.Decimal(10, 2)
  gastos     Decimal @default(0) @db.Decimal(10, 2)

  stockIniAgua  Int @default(0)
  prodAgua      Int @default(0)
  stockFinAgua  Int @default(0)
  stockIniHielo Int @default(0)
  prodHielo     Int @default(0)
  stockFinHielo Int @default(0)

  netoCaja Decimal @default(0) @db.Decimal(10, 2)

  cerradoPor String?
  horaCierre DateTime? @db.Timestamptz()
  reporte    Json?

  createdAt DateTime @default(now()) @db.Timestamptz()
}

// ====================
// NOTA_CREDITO
// ====================

model NotaCredito {
  id        String   @id @default(cuid())
  numero    String   @unique
  pedidoId  String
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
  facturaId String?
  factura   Factura? @relation(fields: [facturaId], references: [id])
  monto     Decimal  @db.Decimal(10, 2)
  motivo    String
  fecha     DateTime @default(now()) @db.Timestamptz()
  creadoPor String?

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([pedidoId])
  @@index([facturaId])
  @@index([fecha])
}

// ====================
// HISTORIAL
// ====================

model Historial {
  id         String   @id @default(cuid())
  entidad    String
  registroId String
  accion     String
  datos      String
  usuarioId  String?
  fecha      DateTime @default(now()) @db.Timestamptz()

  @@index([entidad])
  @@index([fecha])
  @@index([usuarioId])
  @@index([entidad, registroId])
  @@index([entidad, fecha])
}

// ====================
// PRECIO_HISTORIAL
// ====================

model PrecioHistorial {
  id           String   @id @default(cuid())
  producto     String
  precio       Decimal  @db.Decimal(10, 2)
  vigenteDesde DateTime @default(now()) @db.Timestamptz()
  creadoPor    String

  createdAt DateTime @default(now()) @db.Timestamptz()
}

// ====================
// CASOS (Alert Resolution Workflow)
// ====================

model Caso {
  id          String  @id @default(cuid())
  alertaTipo  String
  severidad   String
  titulo      String
  descripcion String? @db.Text

  // Polimórfico: link al negocio. clienteId, pedidoId, negocioId y
  // repartidorId son mutuamente excluyentes (un caso es de UN sujeto).
  clienteId String?
  cliente   Cliente?  @relation("CasoCliente", fields: [clienteId], references: [id], onDelete: SetNull)
  negocioId String?
  negocio   Negocio?  @relation("CasoNegocio", fields: [negocioId], references: [id], onDelete: SetNull)
  pedidoId  String?
  pedido    Pedido?   @relation("CasoPedido", fields: [pedidoId], references: [id], onDelete: SetNull)
  repartidorId String?
  repartidor   Trabajador? @relation("CasoRepartidor", fields: [repartidorId], references: [id], onDelete: SetNull)

  // Workflow
  status      CasoStatus @default(ABIERTO)
  asignadoAId String?
  asignadoA   User?      @relation("CasoAsignado", fields: [asignadoAId], references: [id], onDelete: SetNull)
  creadoPorId String
  creadoPor   User       @relation("CasoCreador", fields: [creadoPorId], references: [id])

  // Resolución
  notasResolucion String?   @db.Text
  resueltoEn      DateTime? @db.Timestamptz()
  cerradoEn       DateTime? @db.Timestamptz()

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  eventos CasoEvento[]

  @@index([status])
  @@index([asignadoAId])
  @@index([clienteId])
  @@index([negocioId])
  @@index([pedidoId])
  @@index([repartidorId])
  @@index([alertaTipo])
  @@index([createdAt])
}

model CasoEvento {
  id         String   @id @default(cuid())
  casoId     String
  caso       Caso     @relation(fields: [casoId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("CasoEventoUser", fields: [userId], references: [id])
  accion     String
  valorPre   String?
  valorPost  String?
  comentario String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz()

  @@index([casoId])
  @@index([createdAt])
}

// ====================
// DEUDA TRABAJADOR (prestamos, deficits)
// ====================

model DeudaTrabajador {
  id           String     @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("DeudaCreador", fields: [createdById], references: [id])
  trabajadorId String
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])

  tipo           String // PRESTAMO, DEFICIT_EFECTIVO, OTRO
  montoOriginal  Decimal @db.Decimal(10, 2)
  montoPendiente Decimal @db.Decimal(10, 2)

  embarqueId  String?
  descripcion String   @db.Text
  fecha       DateTime @default(now()) @db.Timestamptz()

  deducciones DeduccionDeuda[]
  abonos      AbonoDeuda[]
  createdAt   DateTime         @default(now()) @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @db.Timestamptz()

  @@index([trabajadorId])
  @@index([trabajadorId, montoPendiente])
}

// ====================
// ABONO DEUDA (pagos parciales a deuda)
// ====================

model AbonoDeuda {
  id      String          @id @default(cuid())
  deudaId String
  deuda   DeudaTrabajador @relation(fields: [deudaId], references: [id], onDelete: Cascade)
  monto   Decimal         @db.Decimal(10, 2)
  fecha   DateTime        @default(now()) @db.Timestamptz()
  nota    String?         @db.Text

  @@index([deudaId])
}

// ====================
// DEDUCCION DEUDA (trazabilidad nomina -> deuda)
// ====================

model DeduccionDeuda {
  id        String          @id @default(cuid())
  nominaId  String
  nomina    Nomina          @relation(fields: [nominaId], references: [id])
  deudaId   String
  deuda     DeudaTrabajador @relation(fields: [deudaId], references: [id])
  monto     Decimal         @db.Decimal(10, 2)
  createdAt DateTime        @default(now()) @db.Timestamptz()

  @@unique([nominaId, deudaId])
  @@index([nominaId])
  @@index([deudaId])
}

// ====================
// MIGRACIÓN 1FN: ContactoCliente y PlantillaProducto (Fase 1 - EXPAND)
// ====================

model ContactoCliente {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nombre    String
  telefono  String
  relacion  String?

  @@unique([clienteId, telefono])
  @@index([clienteId])
  @@index([telefono])
}

model PlantillaProducto {
  id          String              @id @default(cuid())
  plantillaId String
  plantilla   PlantillaRecurrente @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  producto    String
  cantidad    Int                 @default(0)

  @@unique([plantillaId, producto])
  @@index([plantillaId])
}
