generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ====================
// ENUMS
// ====================

enum EstadoPedido {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  CANCELADO
  ANULADO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
  BONO
}

enum RolUsuario {
  ADMIN
  ASISTENTE
  CONTADOR
}

enum TipoPagoTrabajador {
  COMISION
  FIJO
  MIXTO
}

enum EstadoNomina {
  PENDIENTE
  PAGADA
}

enum EstadoEmbarque {
  ABIERTO
  CERRADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  ANULADA
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

// ====================
// USUARIOS
// ====================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  rol       String   @default("ASISTENTE")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ownership relations
  clientesCreados      Cliente[]         @relation("ClienteCreador")
  pedidosCreados      Pedido[]          @relation("PedidoCreador")
  facturasCreadas     Factura[]         @relation("FacturaCreador")
  embarquesCreados    Embarque[]        @relation("EmbarqueCreador")
  gastosCreados       Gasto[]           @relation("GastoCreador")
  produccionesCreadas Produccion[]      @relation("ProduccionCreador")
  nominasCreadas      Nomina[]          @relation("NominaCreador")
  comprasCreadas      CompraInsumo[]    @relation("CompraCreador")
  insumosCreados      Insumo[]          @relation("InsumoCreador")
  proveedoresCreados  Proveedor[]      @relation("ProveedorCreador")
  trabajadoresCreados Trabajador[]      @relation("TrabajadorCreador")
  rutasCreadas        Ruta[]            @relation("RutaCreador")
}

// ====================
// RUTA (Inteligencia real - rutas con días de entrega)
// ====================

model Ruta {
  id        String   @id @default(cuid())
  createdById String?
  createdBy  User?    @relation("RutaCreador", fields: [createdById], references: [id])
  nombre    String   // "Norte", "Centro", "Sur"
  dias      String?  // "LUN,MIE,VIE" - días de entrega
  activo   Boolean  @default(true)

  clientes  Cliente[]
  embarques Embarque[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// CLIENTE (todo integrado - sin sobre-ingeniería)
// ====================

model Cliente {
  id            String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("ClienteCreador", fields: [createdById], references: [id])

  // Datos básicos
  nombre        String
  apellido     String?
  telefono      String
  direccion    String?
  barrio       String?
  referencia  String?
  linkUbicacion String?

  // Datos del negocio
  nombreNegocio String?
  tipoNegocio   String?
  horaApertura String?
  preciosEspeciales String?  // JSON: {"PACA_AGUA": 2600, "BOTELLON_DOM": 9000}

  // Ubicación - FK a Ruta
  rutaId       String?
  ruta        Ruta?   @relation(fields: [rutaId], references: [id])

  // Frecuencia de pedidos
  frecuencia   String   @default("NINGUNA") // NINGUNA, DIARIA, SEMANAL, QUINCENAL, MENSUAL
  cadaNDias    Int?

  // Control de entregas
  ultEntrega   DateTime?
  proxEntrega DateTime?

  // Preferencias de productos
  habAgua      Boolean @default(true)
  habHielo     Boolean @default(true)
  habBotellon  Boolean @default(true)
  habBolsaAgua Boolean @default(true)
  habBolsaHielo Boolean @default(true)

  notas        String?
  activo      Boolean  @default(true)

  pedidos       Pedido[]
  facturas      Factura[]
  abonos        Abono[]

  createdAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([rutaId])
  @@index([createdById])
}

// ====================
// TRABAJADOR
// ====================

model Trabajador {
  id            String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("TrabajadorCreador", fields: [createdById], references: [id])
  nombre        String
  rol           String   // SELLADOR, REPARTIDOR, ADMIN, CONTADOR (keeping as String for flexibility)
  tipoPago      TipoPagoTrabajador @default(COMISION)

  usaMoto       Boolean  @default(false)
  comPacaAgua   Decimal  @default(200) @db.Decimal(10, 2)
  comPacaHielo  Decimal  @default(200) @db.Decimal(10, 2)
  salarioFijo   Decimal  @default(0)   @db.Decimal(10, 2)

  deudaReposAgua  Decimal  @default(0) @db.Decimal(10, 2)
  deudaReposHielo Decimal  @default(0) @db.Decimal(10, 2)
  telefono      String?
  activo       Boolean  @default(true)

  embarques    Embarque[]
  producciones Produccion[]
  nominas     Nomina[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// NOMINA
// ====================

model Nomina {
  id                String     @id @default(cuid())
  createdById      String?
  createdBy        User?      @relation("NominaCreador", fields: [createdById], references: [id])
  trabajadorId      String
  trabajador       Trabajador @relation(fields: [trabajadorId], references: [id])

  fechaInicio       DateTime
  fechaFin         DateTime

  comEntregasAgua  Decimal   @default(0) @db.Decimal(10, 2)
  comEntregasHielo Decimal   @default(0) @db.Decimal(10, 2)
  totalComisiones  Decimal   @default(0) @db.Decimal(10, 2)

  salario          Decimal   @default(0) @db.Decimal(10, 2)
  total            Decimal   @db.Decimal(10, 2)

  estado        String    @default("PENDIENTE")
  fechaPago    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdById])
}

// ====================
// PEDIDO (productos embebidos, pagos en tabla Pago)
// ====================

model Pedido {
  id          String    @id @default(cuid())
  numero      Int
  createdById String?
  createdBy  User?     @relation("PedidoCreador", fields: [createdById], references: [id])
  clienteId   String
  cliente    Cliente   @relation(fields: [clienteId], references: [id])
  embarqueId String?
  embarque   Embarque? @relation(fields: [embarqueId], references: [id])

  tipo        String    @default("ENVIO")
  estado      EstadoPedido @default(PENDIENTE)

  fechaEntrega DateTime?
  fecha       DateTime  @default(now())

  canal       String    @default("DOMICILIO") // PUNTO, DOMICILIO

  // Productos
  cPacaAguaPed      Int     @default(0)
  cPacaAguaEnt      Int     @default(0)
  precioPacaAgua    Decimal @default(0) @db.Decimal(10, 2)

  cPacaHieloPed     Int     @default(0)
  cPacaHieloEnt     Int     @default(0)
  precioPacaHielo   Decimal @default(0) @db.Decimal(10, 2)

  cBotellonFabPed   Int     @default(0)
  cBotellonFabEnt   Int     @default(0)
  precioBotellonFab Decimal @default(0) @db.Decimal(10, 2)

  cBotellonDomPed   Int     @default(0)
  cBotellonDomEnt   Int     @default(0)
  precioBotellonDom Decimal @default(0) @db.Decimal(10, 2)

  cBolsaAguaPed     Int     @default(0)
  cBolsaAguaEnt     Int     @default(0)
  precioBolsaAgua   Decimal @default(0) @db.Decimal(10, 2)

  cBolsaHieloPed    Int     @default(0)
  cBolsaHieloEnt    Int     @default(0)
  precioBolsaHielo  Decimal @default(0) @db.Decimal(10, 2)

  // Totales
  total        Decimal  @default(0) @db.Decimal(10, 2)
  totalPagado  Decimal  @default(0) @db.Decimal(10, 2)
  saldo        Decimal  @default(0) @db.Decimal(10, 2)

  repartidor   String?
  obs         String?

  // Auto-relación / Recurrencia
  idOrigen     String?
  pedidoOrigen Pedido?  @relation("PedidoHijo", fields: [idOrigen], references: [id])
  pedidoHijo  Pedido[] @relation("PedidoHijo")

  esRecurrente     Boolean   @default(false)
  frecuencia       String?   // DIARIO, SEMANAL, QUINCENAL, MENSUAL
  ultimaGeneracion DateTime?

  factura    Factura?
  pagos      Pago[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId])
  @@index([fecha])
  @@index([estado])
  @@index([createdById])
}

// ====================
// PAGO (múltiples métodos de pago por pedido)
// ====================

model Pago {
  id        String   @id @default(cuid())
  pedidoId  String
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  metodo    String   // MetodoPago enum value
  monto     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([pedidoId])
}

// ====================
// EMBARQUE
// ====================

model Embarque {
  id            String     @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("EmbarqueCreador", fields: [createdById], references: [id])
  numero        Int
  fecha         DateTime   @default(now())
  trabajadorId String
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])
  rutaId        String?
  ruta         Ruta?     @relation(fields: [rutaId], references: [id])
  horaSalida    DateTime?
  horaLlegada   DateTime?
  estado      String     @default("ABIERTO")

  pacasAgua    Int       @default(0)
  pacasHielo  Int       @default(0)
  devueltasAgua Int      @default(0)
  devueltasHielo Int     @default(0)
  rotasAgua    Int       @default(0)
  rotasHielo   Int       @default(0)

  obs         String?

  pedidos     Pedido[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// FACTURA
// ====================

model Factura {
  id          String    @id @default(cuid())
  createdById String?
  createdBy  User?     @relation("FacturaCreador", fields: [createdById], references: [id])
  numero      String    @unique
  clienteId   String
  cliente    Cliente   @relation(fields: [clienteId], references: [id])
  pedidoId    String    @unique
  pedido     Pedido    @relation(fields: [pedidoId], references: [id])

  fecha       DateTime   @default(now())
  subtotal    Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)

  estado     String    @default("EMITIDA")
  notaCredito String?

  montoPagado Decimal  @default(0) @db.Decimal(10, 2)
  saldo       Decimal  @db.Decimal(10, 2)

  abonos    Abono[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pedidoId])
  @@index([clienteId])
  @@index([estado])
  @@index([createdById])
}

// ====================
// ABONO
// ====================

model Abono {
  id          String   @id @default(cuid())
  numero      String  @unique
  facturaId   String
  factura    Factura  @relation(fields: [facturaId], references: [id])
  clienteId  String
  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  monto     Decimal  @db.Decimal(10, 2)
  metodoPago String
  fecha     DateTime @default(now())

  createdAt DateTime @default(now())
}

// ====================
// PRODUCCION
// ====================

model Produccion {
  id             String     @id @default(cuid())
  createdById    String?
  createdBy      User?      @relation("ProduccionCreador", fields: [createdById], references: [id])
  fecha          DateTime    @default(now())
  turno          String     // MANANA, TARDE, NOCHE
  trabajadorId  String
  trabajador   Trabajador  @relation(fields: [trabajadorId], references: [id])

  stockIniAgua   Int        @default(0)
  stockIniHielo Int        @default(0)

  conteoAAgua   Int        @default(0)
  conteoBAgua  Int        @default(0)
  conteoAHielo Int        @default(0)
  conteoBHielo Int        @default(0)

  prodAgua     Int        @default(0)
  prodHielo   Int        @default(0)

  ventasAgua   Int        @default(0)
  ventasHielo Int        @default(0)

  stockFinAgua Int        @default(0)
  stockFinHielo Int      @default(0)

  comSelladorAgua  Decimal @default(0) @db.Decimal(10, 2)
  comSelladorHielo Decimal @default(0) @db.Decimal(10, 2)
  comSellTotal     Decimal @default(0) @db.Decimal(10, 2)

  obs         String?

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// GASTO
// ====================

model Gasto {
  id           String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("GastoCreador", fields: [createdById], references: [id])
  fecha        DateTime @default(now())
  categoria   String
  descripcion String
  monto       Float
  responsable String?
  notas       String?

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// PROVEEDOR
// ====================

model Proveedor {
  id         String     @id @default(cuid())
  createdById String?
  createdBy  User?      @relation("ProveedorCreador", fields: [createdById], references: [id])
  nombre     String
  telefono   String?
  email     String?
  direccion String?
  activo    Boolean   @default(true)

  insumos   Insumo[]
  compras   CompraInsumo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// INSUMO
// ====================

model Insumo {
  id          String     @id @default(cuid())
  createdById String?
  createdBy  User?      @relation("InsumoCreador", fields: [createdById], references: [id])
  nombre     String
  unidad    String
  stock      Decimal    @default(0) @db.Decimal(10, 2)
  stockMin   Decimal    @default(0) @db.Decimal(10, 2)
  precioUnit Decimal    @default(0) @db.Decimal(10, 2)

  proveedorId String?
  proveedor  Proveedor? @relation(fields: [proveedorId], references: [id])

  compras    CompraInsumo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// COMPRA_INSUMO
// ====================

model CompraInsumo {
  id           String    @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("CompraCreador", fields: [createdById], references: [id])
  numero      String    @unique
  proveedorId String
  proveedor  Proveedor @relation(fields: [proveedorId], references: [id])
  insumoId    String
  insumo     Insumo   @relation(fields: [insumoId], references: [id])
  cantidad   Decimal  @db.Decimal(10, 2)
  montoTotal Decimal  @db.Decimal(10, 2)
  fecha      DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

// ====================
// PRODUCTO (catalogo de productos)
// ====================

model Producto {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  unidad      String
  contenido   String?
  activo      Boolean  @default(true)
  
  precios     PrecioVolumen[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ====================
// PRECIO_VOLUMEN (precios por volumen y canal)
// ====================

model PrecioVolumen {
  id          String   @id @default(cuid())
  productoId  String
  producto    Producto @relation(fields: [productoId], references: [id])
  
  canal       String   // PUNTO, DOMICILIO
  cantMin     Int      @default(1)
  cantMax     Int?     // null = unlimited (10+)
  precio      Decimal  @db.Decimal(10, 2)
  
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([productoId])
  @@index([canal])
  @@unique([productoId, canal, cantMin])
}

// ====================
// CONFIG
// ====================

model Config {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

// ====================
// CIERRE_DIA
// ====================

model CierreDia {
  id            String   @id @default(cuid())
  fecha         DateTime @unique

  numPedidos   Int     @default(0)
  totalVentas  Decimal @default(0) @db.Decimal(10, 2)

  aguaVendida    Int     @default(0)
  hieloVendido  Int     @default(0)
  botellonVendido Int   @default(0)
  bolsaAguaVendida Int  @default(0)
  bolsaHieloVendida Int @default(0)

  cobrado       Decimal @default(0) @db.Decimal(10, 2)
  fiado         Decimal @default(0) @db.Decimal(10, 2)
  efectivo      Decimal @default(0) @db.Decimal(10, 2)
  nequi         Decimal @default(0) @db.Decimal(10, 2)
  daviplata     Decimal @default(0) @db.Decimal(10, 2)
  transferencia Decimal @default(0) @db.Decimal(10, 2)
  bono          Decimal @default(0) @db.Decimal(10, 2)

  baseDia       Decimal @default(0) @db.Decimal(10, 2)
  comisiones    Decimal @default(0) @db.Decimal(10, 2)
  salarios      Decimal @default(0) @db.Decimal(10, 2)
  gastos        Decimal @default(0) @db.Decimal(10, 2)

  stockIniAgua Int      @default(0)
  prodAgua    Int      @default(0)
  stockFinAgua Int     @default(0)
  stockIniHielo Int    @default(0)
  prodHielo    Int      @default(0)
  stockFinHielo Int     @default(0)

  netoCaja    Decimal  @default(0) @db.Decimal(10, 2)

  createdAt   DateTime @default(now())
}

// ====================
// HISTORIAL
// ====================

model Historial {
  id         String   @id @default(cuid())
  entidad    String
  registroId String
  accion    String   // CREATE, UPDATE, DELETE
  datos     String   // JSON
  usuarioId String?
  fecha     DateTime @default(now())
}

// ====================
// PRECIO_HISTORIAL
// ====================

model PrecioHistorial {
  id            String   @id @default(cuid())
  producto      String   // AGUA_GALON, HIELO_5KG, BOTELLON_FABRICA, BOTELLON_DOMICILIO, BOLSA_AGUA, BOLSA_HIELO
  precio        Decimal  @db.Decimal(10, 2)
  vigenteDesde  DateTime @default(now())
  creadoPor     String

  createdAt     DateTime @default(now())
}
