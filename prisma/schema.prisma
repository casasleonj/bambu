// ====================
// ABONO
// ====================

model Abono {
  id          String   @id @default(cuid())
  numero      String   @unique
  facturaId   String
  factura     Factura  @relation(fields: [facturaId], references: [id])
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  pedidoId    String?
  pedido      Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  monto       Decimal  @db.Decimal(10, 2)
  metodoPago  String
  fecha       DateTime @db.Timestamptz() @default(now())

  createdAt   DateTime @db.Timestamptz() @default(now())

  @@index([facturaId])
  @@index([clienteId])
  @@index([fecha])
  @@index([facturaId, fecha])
  @@index([pedidoId])
}

// ====================
// PRODUCCION
// ====================

model Produccion {
  id             String     @id @default(cuid())
  createdById    String?
  createdBy      User?      @relation("ProduccionCreador", fields: [createdById], references: [id])
  fecha          DateTime @db.Timestamptz()    @default(now())
  turno          Turno
  trabajadorId  String
  trabajador   Trabajador  @relation(fields: [trabajadorId], references: [id])

  stockIniAgua   Int        @default(0)
  stockIniHielo Int        @default(0)

  conteoAAgua   Int        @default(0)
  conteoBAgua  Int        @default(0)
  conteoAHielo Int        @default(0)
  conteoBHielo Int        @default(0)

  prodAgua     Int        @default(0)
  prodHielo   Int        @default(0)

  ventasAgua   Int        @default(0)
  ventasHielo Int        @default(0)

  stockFinAgua Int        @default(0)
  stockFinHielo Int      @default(0)

  stockFinFisicoAgua    Int        @default(0)
  stockFinFisicoHielo   Int        @default(0)
  filtradasAgua         Int        @default(0)
  filtradasHielo        Int        @default(0)
  rotasAgua             Int        @default(0)
  rotasHielo            Int        @default(0)
  consumoInternoAgua    Int        @default(0)
  consumoInternoHielo   Int        @default(0)

  comSelladorAgua  Decimal @default(0) @db.Decimal(10, 2)
  comSelladorHielo Decimal @default(0) @db.Decimal(10, 2)
  comSellTotal     Decimal @default(0) @db.Decimal(10, 2)

  comRepartidorAgua  Decimal @default(0) @db.Decimal(10, 2)
  comRepartidorHielo Decimal @default(0) @db.Decimal(10, 2)
  comRepartTotal     Decimal @default(0) @db.Decimal(10, 2)

  obs         String?

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([fecha])
  @@index([trabajadorId, fecha])
  @@index([turno, fecha])
  @@unique([trabajadorId, fecha, turno])
}

// ====================
// GASTO
// ====================

model Gasto {
  id           String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("GastoCreador", fields: [createdById], references: [id])
  fecha        DateTime @db.Timestamptz() @default(now())
  categoria   String
  descripcion String
  monto       Decimal  @default(0) @db.Decimal(10, 2)
  responsable String?
  notas       String?
  embarqueId  String?
  embarque    Embarque? @relation(fields: [embarqueId], references: [id])

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([fecha])
  @@index([categoria, fecha])
  @@index([embarqueId])
}

// ====================
// PROVEEDOR
// ====================

model Proveedor {
  id         String     @id @default(cuid())
  createdById String?
  createdBy  User?      @relation("ProveedorCreador", fields: [createdById], references: [id])
  nombre        String
  telefono      String?
  email         String?
  direccion     String?
  tipoProducto  String?   @db.VarChar(100)
  observaciones String?   @db.Text
  activo        Boolean   @default(true)

  insumos   Insumo[]
  compras   CompraInsumo[]

  createdAt DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
}

// ====================
// INSUMO
// ====================

model Insumo {
  id          String     @id @default(cuid())
  createdById String?
  createdBy  User?      @relation("InsumoCreador", fields: [createdById], references: [id])
  nombre     String
  unidad    String
  stock      Decimal    @default(0) @db.Decimal(10, 2)
  stockMin   Decimal    @default(0) @db.Decimal(10, 2)
  precioUnit Decimal    @default(0) @db.Decimal(10, 2)
  activo     Boolean    @default(true)

  proveedorId String?
  proveedor  Proveedor? @relation(fields: [proveedorId], references: [id])

  compras    CompraInsumo[]

  createdAt DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
}

// ====================
// COMPRA_INSUMO
// ====================

model CompraInsumo {
  id           String    @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("CompraCreador", fields: [createdById], references: [id])
  numero      String    @unique
  proveedorId String
  proveedor  Proveedor @relation(fields: [proveedorId], references: [id])
  insumoId    String
  insumo     Insumo   @relation(fields: [insumoId], references: [id])
  cantidad   Decimal  @db.Decimal(10, 2)
  montoTotal Decimal  @db.Decimal(10, 2)
  fecha      DateTime @db.Timestamptz() @default(now())

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([fecha])
  @@index([insumoId])
  @@index([proveedorId])
}

// ====================
// PRODUCTO
// ====================

model Producto {
  id                  String   @id @default(cuid())
  codigo              String   @unique
  nombre              String
  descripcion         String?
  unidad              String
  contenido           String?
  activo              Boolean  @default(true)
  aplicaDomicilio     Boolean  @default(false)
  sobreCostoDomicilio Decimal  @default(0) @db.Decimal(10, 2)

  precios             PrecioVolumen[]

  createdAt           DateTime @db.Timestamptz() @default(now())
  updatedAt           DateTime @db.Timestamptz() @updatedAt
}

// ====================
// PRECIO_VOLUMEN
// ====================

model PrecioVolumen {
  id          String   @id @default(cuid())
  productoId  String
  producto    Producto @relation(fields: [productoId], references: [id])

  cantMin     Int      @default(1)
  cantMax     Int?
  precio      Decimal  @db.Decimal(10, 2)

  activo      Boolean  @default(true)

  createdAt   DateTime @db.Timestamptz() @default(now())
  updatedAt   DateTime @db.Timestamptz() @updatedAt

  @@index([productoId])
  @@index([productoId, activo])
  @@unique([productoId, cantMin])
}

// ====================
// CONFIG
// ====================

model Config {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @db.Timestamptz() @updatedAt
}

// ====================
// CIERRE_DIA
// ====================

model CierreDia {
  id            String   @id @default(cuid())
  fecha         DateTime @db.Timestamptz() @unique

  numPedidos   Int     @default(0)
  totalVentas  Decimal @default(0) @db.Decimal(10, 2)

  // Por origen (nuevos)
  totalVentaRapida  Decimal @default(0) @db.Decimal(10, 2)
  totalPedido       Decimal @default(0) @db.Decimal(10, 2)
  totalVentaLibre   Decimal @default(0) @db.Decimal(10, 2)

  fiadoVentaRapida  Decimal @default(0) @db.Decimal(10, 2)
  fiadoPedido       Decimal @default(0) @db.Decimal(10, 2)
  fiadoVentaLibre   Decimal @default(0) @db.Decimal(10, 2)

  aguaVendida    Int     @default(0)
  hieloVendido  Int     @default(0)
  botellonVendido Int   @default(0)
  bolsaAguaVendida Int  @default(0)
  bolsaHieloVendida Int @default(0)

  cobrado       Decimal @default(0) @db.Decimal(10, 2)
  fiado         Decimal @default(0) @db.Decimal(10, 2)
  efectivo      Decimal @default(0) @db.Decimal(10, 2)
  nequi         Decimal @default(0) @db.Decimal(10, 2)
  daviplata     Decimal @default(0) @db.Decimal(10, 2)
  transferencia Decimal @default(0) @db.Decimal(10, 2)
  bono          Decimal @default(0) @db.Decimal(10, 2)

  baseDia       Decimal @default(0) @db.Decimal(10, 2)
  comisiones    Decimal @default(0) @db.Decimal(10, 2)
  salarios      Decimal @default(0) @db.Decimal(10, 2)
  gastos        Decimal @default(0) @db.Decimal(10, 2)

  stockIniAgua Int      @default(0)
  prodAgua    Int      @default(0)
  stockFinAgua Int     @default(0)
  stockIniHielo Int    @default(0)
  prodHielo    Int      @default(0)
  stockFinHielo Int     @default(0)

  netoCaja    Decimal  @default(0) @db.Decimal(10, 2)

  cerradoPor  String?
  horaCierre  DateTime? @db.Timestamptz()
  reporte     Json?

  createdAt   DateTime @db.Timestamptz() @default(now())
}

// ====================
// NOTA_CREDITO
// ====================

model NotaCredito {
  id          String   @id @default(cuid())
  numero      String   @unique
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
  facturaId   String?
  factura     Factura? @relation(fields: [facturaId], references: [id])
  monto       Decimal  @db.Decimal(10, 2)
  motivo      String
  fecha       DateTime @db.Timestamptz() @default(now())
  creadoPor   String?

  createdAt   DateTime @db.Timestamptz() @default(now())

  @@index([pedidoId])
  @@index([facturaId])
  @@index([fecha])
}

// ====================
// HISTORIAL
// ====================

model Historial {
  id         String   @id @default(cuid())
  entidad    String
  registroId String
  accion    String
  datos     String
  usuarioId String?
  fecha     DateTime @db.Timestamptz() @default(now())

  @@index([entidad])
  @@index([fecha])
  @@index([usuarioId])
  @@index([entidad, registroId])
  @@index([entidad, fecha])
}

// ====================
// PRECIO_HISTORIAL
// ====================

model PrecioHistorial {
  id            String   @id @default(cuid())
  producto      String
  precio        Decimal  @db.Decimal(10, 2)
  vigenteDesde  DateTime @db.Timestamptz() @default(now())
  creadoPor     String

  createdAt     DateTime @db.Timestamptz() @default(now())
}

// ====================
// CASOS (Alert Resolution Workflow)
// ====================

model Caso {
  id              String      @id @default(cuid())
  alertaTipo      String
  severidad       String
  titulo          String
  descripcion     String?     @db.Text

  // Polimórfico: link al negocio
  clienteId       String?
  cliente         Cliente?    @relation("CasoCliente", fields: [clienteId], references: [id], onDelete: SetNull)
  pedidoId        String?
  pedido          Pedido?     @relation("CasoPedido", fields: [pedidoId], references: [id], onDelete: SetNull)

  // Workflow
  status          CasoStatus  @default(ABIERTO)
  asignadoAId     String?
  asignadoA       User?       @relation("CasoAsignado", fields: [asignadoAId], references: [id], onDelete: SetNull)
  creadoPorId     String
  creadoPor       User        @relation("CasoCreador", fields: [creadoPorId], references: [id])

  // Resolución
  notasResolucion String?     @db.Text
  resueltoEn      DateTime?   @db.Timestamptz()
  cerradoEn       DateTime?   @db.Timestamptz()

  createdAt       DateTime    @db.Timestamptz() @default(now())
  updatedAt       DateTime    @db.Timestamptz() @updatedAt

  eventos         CasoEvento[]

  @@index([status])
  @@index([asignadoAId])
  @@index([clienteId])
  @@index([alertaTipo])
  @@index([createdAt])
}

model CasoEvento {
  id          String      @id @default(cuid())
  casoId      String
  caso        Caso        @relation(fields: [casoId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation("CasoEventoUser", fields: [userId], references: [id])
  accion      String
  valorPre    String?
  valorPost   String?
  comentario  String?     @db.Text
  createdAt   DateTime    @db.Timestamptz() @default(now())

  @@index([casoId])
  @@index([createdAt])
}