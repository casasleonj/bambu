generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ====================
// ENUMS
// ====================

enum EstadoPedido {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  CANCELADO
  ANULADO
}

enum EstadoEntrega {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  CANCELADO
  ANULADO
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  ANTICIPADO
  VENCIDO
  ANULADO
}

enum OrigenPedido {
  PEDIDO
  VENTA_RAPIDA
  VENTA_LIBRE
  RECURRENTE
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
  BONO
}

enum RolUsuario {
  ADMIN
  ASISTENTE
  CONTADOR
  REPARTIDOR
  SELLADOR
}

enum TipoPagoTrabajador {
  COMISION
  FIJO
  MIXTO
}

enum EstadoNomina {
  PENDIENTE
  PAGADA
  ANULADA
}

enum EstadoEmbarque {
  ABIERTO
  EN_RUTA
  CERRADO
  CANCELADO
}

enum EstadoFactura {
  EMITIDA
  PAGADA
  ANULADA
  PARCIAL
}

enum Turno {
  MANANA
  TARDE
  NOCHE
}

enum CasoStatus {
  ABIERTO
  EN_PROCESO
  RESUELTO
  CERRADO
}

// ====================
// USUARIOS
// ====================

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nombre    String   @default("")
  apellido  String   @default("")
  rol       RolUsuario @default(ASISTENTE)
  activo    Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  createdAt DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  trabajador  Trabajador?

  clientesCreados      Cliente[]         @relation("ClienteCreador")
  pedidosCreados      Pedido[]          @relation("PedidoCreador")
  facturasCreadas     Factura[]         @relation("FacturaCreador")
  embarquesCreados    Embarque[]        @relation("EmbarqueCreador")
  gastosCreados       Gasto[]           @relation("GastoCreador")
  produccionesCreadas Produccion[]      @relation("ProduccionCreador")
  nominasCreadas      Nomina[]          @relation("NominaCreador")
  comprasCreadas      CompraInsumo[]    @relation("CompraCreador")
  insumosCreados      Insumo[]          @relation("InsumoCreador")
  proveedoresCreados  Proveedor[]      @relation("ProveedorCreador")
   trabajadoresCreados Trabajador[]      @relation("TrabajadorCreador")
  rutasCreadas        Ruta[]            @relation("RutaCreador")
  plantillasCreadas   PlantillaRecurrente[] @relation("PlantillaCreador")

  casosCreados        Caso[]            @relation("CasoCreador")
  casosAsignados      Caso[]            @relation("CasoAsignado")
  eventosCaso         CasoEvento[]      @relation("CasoEventoUser")
}

// ====================
// RUTA
// ====================

model Ruta {
  id        String   @id @default(cuid())
  createdById String?
  createdBy  User?    @relation("RutaCreador", fields: [createdById], references: [id])
  nombre    String
  dias      String?
  activo   Boolean  @default(true)

  repartidorId String?
  repartidor   Trabajador? @relation("RutaRepartidor", fields: [repartidorId], references: [id])
  repartidorRespaldoId String?
  repartidorRespaldo   Trabajador? @relation("RutaRespaldo", fields: [repartidorRespaldoId], references: [id])

  horarioInicio String?
  horarioFin    String?

  clientes  Cliente[]
  embarques Embarque[]

  createdAt DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([repartidorId])
  @@index([repartidorRespaldoId])
}

// ====================
// CLIENTE
// ====================

model Cliente {
  id            String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("ClienteCreador", fields: [createdById], references: [id])

  nombre        String
  apellido     String?
  telefono      String
  direccion    String?
  barrio       String?
  referencia  String?
  linkUbicacion String?
  contactos     Json?

  nombreNegocio String?
  tipoNegocio   String?
  fuente        String?
  horaApertura String?
  preciosEspeciales String?

  rutaId       String?
  ruta        Ruta?   @relation(fields: [rutaId], references: [id])

  frecuencia   String   @default("NINGUNA")
  cadaNDias    Int?

  ultEntrega   DateTime? @db.Timestamptz()
  proxEntrega DateTime? @db.Timestamptz()

  habAgua      Boolean @default(true)
  habHielo     Boolean @default(true)
  habBotellon  Boolean @default(true)
  habBolsaAgua Boolean @default(true)
  habBolsaHielo Boolean @default(true)

  // NUEVOS — control y verificación
  verificado     Boolean   @default(false)
  verificadoEn   DateTime? @db.Timestamptz()
  creadoPorRol   RolUsuario @default(ASISTENTE)
  bloqueado      Boolean   @default(false)
  reclamaciones  Int       @default(0)
  limitePedidosFiados Int? @default(3)

  plantillaRecurrente PlantillaRecurrente?

  notas        String?
  activo      Boolean  @default(true)

  pedidos       Pedido[]
  facturas      Factura[]
  abonos        Abono[]
  casos         Caso[]        @relation("CasoCliente")

  createdAt   DateTime @db.Timestamptz() @default(now())
  updatedAt  DateTime @db.Timestamptz() @updatedAt

  @@index([rutaId])
  @@index([createdById])
  @@index([telefono])
  @@index([activo])
  @@index([barrio])
  @@index([frecuencia])
  @@index([proxEntrega])
  @@index([verificado])
  @@index([bloqueado])
}

// ====================
// PLANTILLA RECURRENTE
// ====================

model PlantillaRecurrente {
  id              String   @id @default(cuid())
  clienteId       String   @unique
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  activo          Boolean  @default(true)
  cadaNDias       Int      @default(7)
  tipo            String   @default("ENVIO")
  canal           String   @default("DOMICILIO")
  horaPreferida   String?
  productos       String   // JSON: {"PACA_AGUA":2,"PACA_HIELO":0,...}
  ultimaGeneracion DateTime? @db.Timestamptz()
  proxGeneracion  DateTime? @db.Timestamptz()
  saltos          String[]
  pausaHasta      DateTime? @db.Timestamptz()
  notas           String?
  createdById     String?
  createdBy       User?    @relation("PlantillaCreador", fields: [createdById], references: [id])
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  @@index([activo, proxGeneracion])
  @@index([clienteId])
}

// ====================
// TRABAJADOR
// ====================

model Trabajador {
  id            String   @id @default(cuid())
  createdById  String?
  createdBy    User?    @relation("TrabajadorCreador", fields: [createdById], references: [id])
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])
  nombre        String
  rol           String
  tipoPago      TipoPagoTrabajador @default(COMISION)

  usaMoto       Boolean  @default(false)
  capacidadKg   Int      @default(500)
  comPacaAgua   Decimal  @default(200) @db.Decimal(10, 2)
  comPacaHielo  Decimal  @default(200) @db.Decimal(10, 2)
  comBotellon   Decimal  @default(200) @db.Decimal(10, 2)

  comRepartAgua    Decimal  @default(0) @db.Decimal(10, 2)
  comRepartHielo   Decimal  @default(0) @db.Decimal(10, 2)
  comRepartBotellon Decimal  @default(0) @db.Decimal(10, 2)

  salarioFijo   Decimal  @default(0)   @db.Decimal(10, 2)

  deudaReposAgua  Decimal  @default(0) @db.Decimal(10, 2)
  deudaReposHielo Decimal  @default(0) @db.Decimal(10, 2)
  telefono      String?
  activo       Boolean  @default(true)

  embarques    Embarque[]
  producciones Produccion[]
  nominas     Nomina[]
  gpsTracks    GpsTrack[]
  descuentos   DescuentoRepartidor[]

  rutasAsignadas    Ruta[] @relation("RutaRepartidor")
  rutasRespaldo     Ruta[] @relation("RutaRespaldo")

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([rol, activo])
}

// ====================
// NOMINA
// ====================

model Nomina {
  id                String     @id @default(cuid())
  createdById      String?
  createdBy        User?      @relation("NominaCreador", fields: [createdById], references: [id])
  trabajadorId      String
  trabajador       Trabajador @relation(fields: [trabajadorId], references: [id])

  fechaInicio       DateTime @db.Timestamptz()
  fechaFin         DateTime @db.Timestamptz()

  entregasAgua     Int       @default(0)
  entregasHielo    Int       @default(0)
  entregasBotellon Int       @default(0)

  comEntregasAgua  Decimal   @default(0) @db.Decimal(10, 2)
  comEntregasHielo Decimal   @default(0) @db.Decimal(10, 2)
  comEntregasBotellon Decimal @default(0) @db.Decimal(10, 2)
  totalComisiones  Decimal   @default(0) @db.Decimal(10, 2)

  // NUEVOS — comisiones por origen
  comVentaLibreAgua   Decimal @default(0) @db.Decimal(10, 2)
  comVentaLibreHielo  Decimal @default(0) @db.Decimal(10, 2)
  comPedidoAgua       Decimal @default(0) @db.Decimal(10, 2)
  comPedidoHielo      Decimal @default(0) @db.Decimal(10, 2)

  salario          Decimal   @default(0) @db.Decimal(10, 2)
  total            Decimal   @db.Decimal(10, 2)

  estado        EstadoNomina @default(PENDIENTE)
  fechaPago    DateTime? @db.Timestamptz()

  createdAt    DateTime @db.Timestamptz() @default(now())
  updatedAt    DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([trabajadorId])
  @@index([estado])
}

// ====================
// PEDIDO (con legacy + nuevos campos)
// ====================

model Pedido {
  id          String    @id @default(cuid())
  numero      Int       @default(autoincrement())
  createdById String?
  createdBy  User?     @relation("PedidoCreador", fields: [createdById], references: [id])
  clienteId   String
  cliente    Cliente   @relation(fields: [clienteId], references: [id])
  embarqueId String?
  embarque   Embarque? @relation(fields: [embarqueId], references: [id])

  tipo        String    @default("ENVIO")
  canal       String    @default("DOMICILIO")

  fechaEntrega DateTime? @db.Timestamptz()
  fecha       DateTime @db.Timestamptz()  @default(now())

  // NUEVOS — estado desacoplado
  origen        OrigenPedido     @default(PEDIDO)
  estadoEntrega EstadoEntrega    @default(PENDIENTE)
  estadoPago    EstadoPago       @default(PENDIENTE)

  // NUEVOS — control y trazabilidad
  promesaPagoFecha  DateTime?   @db.Timestamptz()
  fotoEntrega       String?
  gpsLat            Decimal?    @db.Decimal(10, 6)
  gpsLng            Decimal?    @db.Decimal(10, 6)
  offlineId         String?     @unique
  disputaAbierta    Boolean     @default(false)
  codigoVisita      String?

  // LEGACY — se mantiene para compatibilidad
  estado      EstadoPedido     @default(PENDIENTE)

  // Productos embebidos (DEPRECATED — leer desde items[])
  cPacaAguaPed      Int     @default(0)
  cPacaAguaEnt      Int     @default(0)
  precioPacaAgua    Decimal @default(0) @db.Decimal(10, 2)

  cPacaHieloPed     Int     @default(0)
  cPacaHieloEnt     Int     @default(0)
  precioPacaHielo   Decimal @default(0) @db.Decimal(10, 2)

  cBotellonFabPed   Int     @default(0)
  cBotellonFabEnt   Int     @default(0)
  precioBotellonFab Decimal @default(0) @db.Decimal(10, 2)

  cBotellonDomPed   Int     @default(0)
  cBotellonDomEnt   Int     @default(0)
  precioBotellonDom Decimal @default(0) @db.Decimal(10, 2)

  cBolsaAguaPed     Int     @default(0)
  cBolsaAguaEnt     Int     @default(0)
  precioBolsaAgua   Decimal @default(0) @db.Decimal(10, 2)

  cBolsaHieloPed    Int     @default(0)
  cBolsaHieloEnt    Int     @default(0)
  precioBolsaHielo  Decimal @default(0) @db.Decimal(10, 2)

  // Totales
  total        Decimal  @default(0) @db.Decimal(10, 2)
  totalPagado  Decimal  @default(0) @db.Decimal(10, 2)
  saldo        Decimal  @default(0) @db.Decimal(10, 2)

  repartidor   String?
  obs         String?
  horaPreferida String?

  // Referencia polimórfica: PlantillaRecurrente.id o null
  idOrigen     String?

  // Relaciones nuevas
  items         PedidoItem[]

  factura    Factura?
  pagos      Pago[]
  notasCredito NotaCredito[]
  abonos     Abono[]
  casos      Caso[]    @relation("CasoPedido")

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([clienteId])
  @@index([embarqueId])
  @@index([fecha])
  @@index([estado])
  @@index([createdById])
  @@index([idOrigen])
  @@index([fecha, estado])
  @@index([clienteId, estado])
  @@index([estado, fecha])
  @@index([embarqueId, estado])
  @@index([canal, estado])
  @@index([fechaEntrega])
  // NUEVOS índices
  @@index([origen])
  @@index([estadoEntrega])
  @@index([estadoPago])
  @@index([offlineId])
  @@index([clienteId, estadoEntrega, estadoPago])
  @@index([promesaPagoFecha])
}

// ====================
// PEDIDO ITEM (nueva tabla normalizada)
// ====================

model PedidoItem {
  id          String   @id @default(cuid())
  pedidoId    String
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  producto    String   // PACA_AGUA, PACA_HIELO, BOTELLON, BOLSA_AGUA, BOLSA_HIELO
  cantPedido  Int      @default(0)
  cantEntrega Int      @default(0)
  precio      Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @default(0) @db.Decimal(10, 2)

  @@index([pedidoId])
  @@index([producto])
}

// ====================
// PAGO
// ====================

model Pago {
  id        String   @id @default(cuid())
  pedidoId  String
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  metodo    MetodoPago
  monto     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @db.Timestamptz() @default(now())

  @@index([pedidoId])
}

// ====================
// EMBARQUE
// ====================

model Embarque {
  id            String     @id @default(cuid())
  createdById  String?
  createdBy    User?      @relation("EmbarqueCreador", fields: [createdById], references: [id])
  numero        Int       @default(autoincrement())
  numeroDia     Int       @default(0)
  fecha         DateTime @db.Timestamptz()   @default(now())
  trabajadorId String
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])
  rutaId        String?
  ruta         Ruta?     @relation(fields: [rutaId], references: [id])
  horaSalida    DateTime? @db.Timestamptz()
  horaLlegada   DateTime? @db.Timestamptz()
  estado      EstadoEmbarque @default(ABIERTO)

  // Legacy — se mantiene para compatibilidad
  pacasAgua    Int       @default(0)
  pacasHielo  Int       @default(0)
  devueltasAgua Int      @default(0)
  devueltasHielo Int     @default(0)
  rotasAgua    Int       @default(0)
  rotasHielo   Int       @default(0)

  // Tipo de motocarga
  tipoMoto      String?

  // Dinero
  baseDinero    Decimal   @default(0) @db.Decimal(10, 2)
  dineroEntregado Decimal @default(0) @db.Decimal(10, 2)

  // Snapshot de stock al crear
  stockSnapshot Json?

  // NUEVO — código de visita del día
  codigoVisita  String?

  obs         String?

  pedidos     Pedido[]
  gpsTracks   GpsTrack[]
  productos   EmbarqueProducto[]
  gastos      Gasto[]

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([createdById])
  @@index([trabajadorId])
  @@index([rutaId])
  @@index([fecha])
  @@index([estado])
  @@index([trabajadorId, fecha, numeroDia])
}

// ====================
// EMBARQUE PRODUCTO (conciliación por producto)
// ====================

model EmbarqueProducto {
  id          String   @id @default(cuid())
  embarqueId  String
  embarque    Embarque @relation(fields: [embarqueId], references: [id], onDelete: Cascade)

  producto    String   // PACA_AGUA, PACA_HIELO, BOTELLON, BOLSA_AGUA, BOLSA_HIELO
  cargadas    Int      @default(0)
  devueltas   Int      @default(0)
  cambios     Int      @default(0)
  rotas       Int      @default(0)

  @@unique([embarqueId, producto])
  @@index([embarqueId])
}

// ====================
// GPS TRACK (nueva)
// ====================

model GpsTrack {
  id            String   @id @default(cuid())
  embarqueId    String
  trabajadorId  String
  lat           Decimal  @db.Decimal(10, 6)
  lng           Decimal  @db.Decimal(10, 6)
  timestamp     DateTime @db.Timestamptz()
  synced        Boolean  @default(false)

  embarque      Embarque   @relation(fields: [embarqueId], references: [id])
  trabajador    Trabajador @relation(fields: [trabajadorId], references: [id])

  @@index([embarqueId])
  @@index([trabajadorId, timestamp])
}

// ====================
// DESCUENTO REPARTIDOR (nueva)
// ====================

model DescuentoRepartidor {
  id                String   @id @default(cuid())
  embarqueId        String
  trabajadorId      String
  monto             Decimal  @db.Decimal(10, 2)
  motivo            String
  justificado       Boolean  @default(false)
  aplicadoEnNomina  Boolean  @default(false)
  fecha             DateTime @db.Timestamptz() @default(now())

  trabajador        Trabajador @relation(fields: [trabajadorId], references: [id])

  @@index([trabajadorId])
  @@index([embarqueId])
  @@index([aplicadoEnNomina])
}

// ====================
// FACTURA
// ====================

model Factura {
  id          String    @id @default(cuid())
  createdById String?
  createdBy  User?     @relation("FacturaCreador", fields: [createdById], references: [id])
  numero      String    @unique
  clienteId   String
  cliente    Cliente   @relation(fields: [clienteId], references: [id])
  pedidoId    String    @unique
  pedido     Pedido    @relation(fields: [pedidoId], references: [id])

  fecha       DateTime @db.Timestamptz()   @default(now())
  subtotal    Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)

  estado     EstadoFactura @default(EMITIDA)

  montoPagado Decimal  @default(0) @db.Decimal(10, 2)
  saldo       Decimal  @db.Decimal(10, 2)

  // Snapshot de datos de empresa al momento de emisión (inmutable)
  empresaNombre    String?   @default("Agua Bambu SAS")
  empresaNit       String?   @default("900.123.456-7")
  empresaDireccion String?   @default("")
  empresaTelefono  String?   @default("")
  empresaEmail     String?   @default("")

  abonos    Abono[]
  notasCredito NotaCredito[]

  createdAt  DateTime @db.Timestamptz() @default(now())
  updatedAt DateTime @db.Timestamptz() @updatedAt

  @@index([clienteId])
  @@index([estado])
  @@index([createdById])
  @@index([saldo])
  @@index([fecha])
}

